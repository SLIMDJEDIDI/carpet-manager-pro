generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
  output        = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Brand {
  id        String      @id @default(cuid())
  name      String      @unique
  createdAt DateTime    @default(now())
  items     OrderItem[]
}

model Design {
  id        String      @id @default(cuid())
  code      String      @unique
  name      String
  imageUrl  String?
  createdAt DateTime    @default(now())
  items     OrderItem[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("ORDER") // ADMIN, ORDER, DESIGNER, PRODUCTION, SHIPPING, ACCOUNTING
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdOrders   Order[] @relation("CreatedBy")
  confirmedOrders Order[] @relation("ConfirmedBy")
  jaxLogs         JaxLog[]
}

model Order {
  id                  String      @id @default(cuid())
  reference           Int?        @unique
  customerName        String
  customerPhone       String
  customerAddress     String
  customerPostalCode  String?
  customerGovernorate String?
  customerDelegation  String?
  status              String      @default("PENDING") // PENDING, CONFIRMED, ON_HOLD, READY_TO_SHIP, SHIPPED, DISPATCHED, DELIVERED, RETURNED, CANCELLED
  totalAmount         Float       @default(0)
  parcelNumber        String?
  jaxTrackingId       String?
  jaxReceiptUrl       String?
  isFreeDelivery      Boolean     @default(false)
  isExchange          Boolean     @default(false)
  note                String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  
  createdById         String?
  confirmedById       String?
  createdBy           User?       @relation("CreatedBy", fields: [createdById], references: [id])
  confirmedBy         User?       @relation("ConfirmedBy", fields: [confirmedById], references: [id])

  items               OrderItem[]
  jaxLogs             JaxLog[]
}

model OrderItem {
  id               String          @id @default(cuid())
  orderId          String
  size             String
  price            Float           @default(0)
  isPack           Boolean         @default(false)
  parentItemId     String?
  brandId          String
  designId         String
  status           String          @default("PENDING") // PENDING, IN_PRODUCTION, DAMAGED, WRAPPED, SHIPPED
  designStatus     String          @default("PENDING") // PENDING, READY
  productionListId String?
  jaxLogId         String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  
  productionList   ProductionList? @relation(fields: [productionListId], references: [id])
  design           Design          @relation(fields: [designId], references: [id])
  brand            Brand           @relation(fields: [brandId], references: [id])
  order            Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  parentItem       OrderItem?      @relation("PackItems", fields: [parentItemId], references: [id])
  subItems         OrderItem[]     @relation("PackItems")
  jaxLog           JaxLog?         @relation(fields: [jaxLogId], references: [id])
}

model JaxLog {
  id            String   @id @default(cuid())
  orderId       String
  requestBody   String   @db.Text
  responseBody  String   @db.Text
  status        String   // SUCCESS, ERROR
  trackingId    String?
  receiptUrl    String?
  userId        String?
  createdAt     DateTime @default(now())

  order         Order    @relation(fields: [orderId], references: [id])
  user          User?    @relation(fields: [userId], references: [id])
  items         OrderItem[]
}

model Product {
  id          String   @id @default(cuid())
  brandId     String
  category    String   // Salon, Chambre, Couloir, etc.
  name        String   // e.g. "Tapis 160 x 210" or "Pack Chambre"
  size        String   // for display
  price       Float
  isPack      Boolean  @default(false)
  components  String?  // JSON string: [{size: "100x150", qty: 1}, {size: "75x100", qty: 2}]
  createdAt   DateTime @default(now())
}

model ProductionList {
  id        String      @id @default(cuid())
  batchName String
  createdAt DateTime    @default(now())
  items     OrderItem[]
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String   // e.g., "CREATE_ORDER", "START_PRODUCTION", "SHIP_ORDER"
  details   String   // Text description
  metadata  String?  // JSON string for technical details
  createdAt DateTime @default(now())
}
